# === Required ===
# Claude API for AI summaries
ANTHROPIC_API_KEY=sk-ant-xxx

# Postgres password (used by db, pipeline, service)
POSTGRES_PASSWORD=devpass

# === App (Streamlit) ===
# Points to the `service` container on the compose network.
# For local dev (no compose), use http://localhost:8000
API_BASE=http://service:8000

# Brinson engine mode: BF2 or BF3
BRINSON_MODE=BF2

# Rate limit for TWSE fetches (seconds)
TWSE_RATE_LIMIT_DELAY=2.0

# Local cache directory for SITCA Excel files
SITCA_DATA_DIR=data/sitca_raw

# === Pipeline (optional data source tokens) ===
FINNHUB_API_KEY=
FINMIND_API_TOKEN=

# Scheduler timezone
SCHEDULER_TIMEZONE=Asia/Taipei
